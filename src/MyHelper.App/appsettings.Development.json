{
  "MyHelper": {
    "Memory": {
      "DatabasePath": "memory.dev.db",
      "AutoCaptureEnabled": true,
      "AutoCaptureThreshold": 0.92,
      "MaxSearchResults": 50
    },
    "McpServers": {
      "learn": {
        "Type": "http",
        "Url": "https://learn.microsoft.com/api/mcp"
      }
    },
    "Skills": {
      "Enabled": true,
      "Catalog": {
        "ms-learn-search": {
          "DisplayName": "Microsoft Learn",
          "Description": "Search and summarize Microsoft Learn guidance.",
          "PromptTemplate": "Use the Microsoft Learn MCP server to answer the request. Cite official Learn pages when possible.\n\nUser request:\n{input}",
          "McpServers": [ "learn" ]
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

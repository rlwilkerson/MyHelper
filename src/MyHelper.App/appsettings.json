{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MyHelper": "Debug"
    }
  },
  "AllowedHosts": "*",
  "MyHelper": {
    "CliUrl": "",
    "GitHubToken": "",
    "DefaultModel": "gpt-4.1",
    "SystemMessage": "You are MyHelper, a local AI assistant. You have access to tools for reading files, running shell commands, and making HTTP requests. Be concise and accurate.",
    "McpServers": {},
    "Memory": {
      "DatabasePath": "memory.db",
      "AutoCaptureEnabled": true,
      "AutoCaptureThreshold": 0.92,
      "MaxSearchResults": 50
    },
    "ShellCommandAllowList": [
      "git", "dotnet", "npm", "node", "python",
      "ls", "dir", "cat", "echo", "pwd", "which", "where"
    ]
  }
}

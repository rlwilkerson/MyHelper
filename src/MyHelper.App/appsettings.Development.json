{
  "MyHelper": {
    "Memory": {
      "DatabasePath": "memory.dev.db",
      "AutoCaptureEnabled": true,
      "AutoCaptureThreshold": 0.92,
      "MaxSearchResults": 50
    },
    "McpServers": {
      "learn": {
        "Type": "http",
        "Url": "https://learn.microsoft.com/api/mcp"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
